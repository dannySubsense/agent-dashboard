# GitHub Personal Access Token — dannySubsense account, repo scope required.
# Panels that depend on GitHub (Open Work PRs/issues, Project Cards PR count) will
# show "unavailable" when this is missing, but the rest of the dashboard runs normally.
GITHUB_TOKEN=

# Postgres connection string for the LORE backend on VM 103.
# Include sslmode=disable — the connection is over Tailscale (no TLS needed).
# Example: postgres://lore:<password>@<lore-db-host>:5432/lore?sslmode=disable
# LORE-dependent panels (Session Close, Agent Status, HALT data) show "unavailable"
# when this is missing.
LORE_DATABASE_URL=

# Parent directory scanned one level deep for git repos. Colon-separated for multiple.
# Defaults to ~/projects when neither this nor PROJECT_PATHS is set.
# PROJECTS_ROOT=/home/d-tuned/projects

# Explicit individual repo paths, colon-separated. For repos not under PROJECTS_ROOT.
# PROJECT_PATHS=/srv/some-repo:/opt/another-repo
